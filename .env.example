XAI_API_KEY=여기에_xAI_Grok_API_키를_넣어주세요
XAI_MODEL=grok-4

# 이미지 생성 제공자: google 또는 openai
IMAGE_PROVIDER=google

# Google Gemini / Nano Banana 이미지 생성
GEMINI_API_KEY=여기에_Google_Gemini_API_키를_넣어주세요
GOOGLE_IMAGE_MODEL=gemini-3.1-flash-image

# Google Veo 영상 생성 (영상화 하기 단계, GEMINI_API_KEY 공유)
GOOGLE_VIDEO_MODEL=veo-3.1-fast-generate-preview
GOOGLE_VIDEO_RESOLUTION=720p
GOOGLE_VIDEO_DURATION_SECONDS=4

# OpenAI 이미지 생성으로 바꿀 때 사용
OPENAI_API_KEY=여기에_OpenAI_API_키를_넣어주세요
OPENAI_IMAGE_MODEL=gpt-image-1
